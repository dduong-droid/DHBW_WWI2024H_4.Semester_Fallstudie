# Backend local demo
APP_NAME=Food 4 Recovery
APP_ENV=development
APP_PORT=8000
DATABASE_URL=sqlite:///./food4recovery.db
FRONTEND_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional MVP/demo API key. Leave empty for local development without API-key checks.
API_KEY=

# Frontend local demo
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Browser-visible demo helper only. Do not treat this as a real secret.
NEXT_PUBLIC_API_KEY=

# Optional hard mode for integration checks. If true, frontend API failures are not hidden by mock fallback data.
NEXT_PUBLIC_DISABLE_MOCK_FALLBACK=false
